# مفتاح OpenAI — مطلوب لتوليد القصة والصورة
OPENAI_API_KEY=sk-...

# (اختياري) تخصيص النماذج المستخدمة
# OPENAI_TEXT_MODEL=gpt-5.1
# OPENAI_IMAGE_MODEL=gpt-image-1
# جودة الصورة: low أسرع، medium متوازنة (الافتراضي)، high أجمل لكن أبطأ
# OPENAI_IMAGE_QUALITY=medium

# (اختياري) الحفظ التلقائي للقيم الجديدة في المكتبة عبر GitHub
# مفتاح GitHub بصلاحية الكتابة على المحتوى (Fine-grained: Contents = Read and write)
# GITHUB_TOKEN=github_pat_...
# اسم المستودع الذي تُحفظ فيه القيم الجديدة
# GITHUB_REPO=Cyanera/Ghiras
# الفرع (اختياري، الافتراضي main)
# GITHUB_BRANCH=main

# ===== الخدمات المدفوعة (فرع التطوير) =====
# وضع الدفع: mock (تجريبي محلي) أو moyasar
# PAYMENTS_MODE=mock
# الرابط الأساسي للموقع (للتحويل بعد الدفع وروابط البريد)
# NEXT_PUBLIC_BASE_URL=http://localhost:3000
# مفتاح ميسّر السري (وضع moyasar)
# MOYASAR_SECRET_KEY=sk_test_...
# توقيع ويب هوك ميسّر (اختياري، طبقة حماية)
# MOYASAR_WEBHOOK_SECRET=...
# مفتاح Resend لإرسال البريد (وإلا يُسجَّل فقط في وضع التطوير)
# RESEND_API_KEY=re_...
# EMAIL_FROM=غِراس <noreply@ghiras.kids>

# مخزن الطلبات الدائم (Supabase) — للإنتاج
# SUPABASE_URL=https://xxxx.supabase.co
# SUPABASE_SERVICE_ROLE_KEY=eyJ...

# مفتاح OpenAI — مطلوب لتوليد القصة والصورة
OPENAI_API_KEY=sk-...

# (اختياري) تخصيص النماذج المستخدمة
# OPENAI_TEXT_MODEL=gpt-5.1
# OPENAI_IMAGE_MODEL=gpt-image-1
# جودة الصورة: low أسرع، medium متوازنة (الافتراضي)، high أجمل لكن أبطأ
# OPENAI_IMAGE_QUALITY=medium

# (اختياري) الحفظ التلقائي للقيم الجديدة في المكتبة عبر GitHub
# مفتاح GitHub بصلاحية الكتابة على المحتوى (Fine-grained: Contents = Read and write)
# GITHUB_TOKEN=github_pat_...
# اسم المستودع الذي تُحفظ فيه القيم الجديدة
# GITHUB_REPO=Cyanera/Ghiras
# الفرع (اختياري، الافتراضي main)
# GITHUB_BRANCH=main
